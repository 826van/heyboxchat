{
  "manifest_version": 3,
  "name": "Xiaohongshu Keyword Helper",
  "version": "0.1.0",
  "description": "Find keyword-matching notes on xiaohongshu.com and prepare manual comment drafts.",
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaohongshu.com/*",
        "https://xiaohongshu.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
